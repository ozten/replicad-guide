---
import VersionBadge from "../components/VersionBadge.astro";
import { withBase } from "../lib/base-url";

export type Section = { id: string; title: string };

interface Props {
  title: string;
  description?: string;
  /** In-page sections, rendered as the sticky TOC / section nav. */
  sections?: Section[];
}

const { title, description, sections = [] } = Astro.props;

const nav = [
  { href: withBase("/"), label: "replicad guide" },
  { href: withBase("/2d"), label: "2D quick ref" },
  { href: withBase("/3d"), label: "3D quick ref" },
  { href: withBase("/reference"), label: "Full API" },
];
// pathname carries the base too, so comparisons stay symmetric once both
// sides drop the trailing slash
const normalize = (path: string) => path.replace(/\/$/, "") || "/";
const home = normalize(withBase("/"));
const currentPath = normalize(Astro.url.pathname);
const isCurrent = (href: string) => {
  const target = normalize(href);
  return (
    target === currentPath ||
    (target !== home && currentPath.startsWith(`${target}/`))
  );
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — replicad guide</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <header class="site-header">
      <nav class="global-nav" aria-label="Site">
        {
          nav.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="site-search" data-search>
        <input
          type="search"
          placeholder="Search the API…  /"
          aria-label="Search the API"
          autocomplete="off"
          role="combobox"
          aria-expanded="false"
          aria-controls="search-results"
          data-search-input
        />
        <ul
          class="search-results"
          id="search-results"
          role="listbox"
          hidden
          data-search-results
        >
        </ul>
      </div>
      <div class="header-badge"><VersionBadge /></div>
    </header>

    <div class:list={["page", { "with-nav": sections.length > 0 }]}>
      {
        sections.length > 0 && (
          <nav class="section-nav" aria-label="On this page">
            <ul>
              {sections.map((section) => (
                <li>
                  <a href={`#${section.id}`}>{section.title}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
      <main>
        <h1>{title}</h1>
        <slot />
      </main>
    </div>

    <footer class="site-footer">
      <p>
        Complements the
        <a href="https://replicad.xyz/docs/tutorial-overview">tutorial</a> — start
        there if you're new. Embedding replicad?
        <a href="https://replicad.xyz/docs/use-as-a-library/">Use as a library</a>.
      </p>
      <VersionBadge />
    </footer>
  </body>
</html>

<script>
  // Site-wide search (U8): fetches the static index on first use and ranks
  // with the same scoring module the tests exercise (src/lib/search-index).
  // Index hrefs are stored base-free; the base is prefixed here, the one
  // place that turns them into links.
  import { searchDocs, type SearchDoc } from "../lib/search-index";

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

  const root = document.querySelector("[data-search]");
  const input = root?.querySelector<HTMLInputElement>("[data-search-input]");
  const list = root?.querySelector<HTMLUListElement>("[data-search-results]");

  if (root && input && list) {
    let docs: SearchDoc[] | null = null;
    let loading: Promise<SearchDoc[]> | null = null;
    let active = -1;

    const loadDocs = () => {
      loading ??= fetch(`${BASE}/search-index.json`)
        .then((response) => response.json())
        .then((data: SearchDoc[]) => (docs = data));
      return loading;
    };

    const close = () => {
      list.hidden = true;
      input.setAttribute("aria-expanded", "false");
      active = -1;
    };

    const render = (results: SearchDoc[]) => {
      list.textContent = "";
      active = -1;
      if (results.length === 0) {
        close();
        return;
      }
      for (const [index, doc] of results.entries()) {
        const item = document.createElement("li");
        item.role = "option";
        item.id = `search-option-${index}`;
        const link = document.createElement("a");
        link.href = `${BASE}${doc.href}`;
        const label = document.createElement("span");
        label.className = "result-label";
        label.textContent = doc.label;
        const detail = document.createElement("span");
        detail.className = "result-detail";
        detail.textContent = doc.detail;
        link.append(label, detail);
        item.append(link);
        list.append(item);
      }
      list.hidden = false;
      input.setAttribute("aria-expanded", "true");
    };

    const setActive = (next: number) => {
      const options = [...list.querySelectorAll("li")];
      if (options.length === 0) return;
      active = (next + options.length) % options.length;
      options.forEach((option, index) =>
        option.classList.toggle("active", index === active),
      );
      input.setAttribute("aria-activedescendant", `search-option-${active}`);
    };

    input.addEventListener("focus", () => void loadDocs());
    input.addEventListener("input", async () => {
      await loadDocs();
      render(searchDocs(docs ?? [], input.value));
    });

    input.addEventListener("keydown", (event) => {
      if (event.key === "ArrowDown") {
        event.preventDefault();
        setActive(active + 1);
      } else if (event.key === "ArrowUp") {
        event.preventDefault();
        setActive(active - 1);
      } else if (event.key === "Enter") {
        const chosen =
          list.querySelectorAll("a")[active >= 0 ? active : 0];
        if (chosen && !list.hidden) {
          event.preventDefault();
          window.location.href = chosen.href;
        }
      } else if (event.key === "Escape") {
        close();
        input.blur();
      }
    });

    document.addEventListener("click", (event) => {
      if (!root.contains(event.target as Node)) close();
    });

    // "/" focuses search from anywhere (unless already typing somewhere)
    document.addEventListener("keydown", (event) => {
      if (event.key !== "/" || event.ctrlKey || event.metaKey || event.altKey) return;
      const target = event.target as HTMLElement | null;
      if (target && /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName)) return;
      if (target?.isContentEditable) return;
      event.preventDefault();
      input.focus();
    });
  }
</script>

<style is:global>
  :root {
    color-scheme: light dark;
    --accent: #0e7490;
    --muted: #6b7280;
    --border: color-mix(in srgb, currentColor 18%, transparent);
    --header-h: 3.5rem;
  }
  * {
    box-sizing: border-box;
  }
  /* Anchor jumps must land below the sticky header. */
  html {
    scroll-padding-top: calc(var(--header-h) + 0.5rem);
  }
  body {
    margin: 0;
    font-family: system-ui, sans-serif;
    line-height: 1.55;
  }
  /* Wide code and signatures scroll inside their block, never the page. */
  pre {
    overflow-x: auto;
  }
</style>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: Canvas;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    min-height: var(--header-h);
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .global-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem;
  }
  .global-nav a {
    text-decoration: none;
    color: inherit;
  }
  .global-nav a:first-child {
    font-weight: 700;
  }
  .global-nav a:hover {
    color: var(--accent);
  }
  .global-nav a[aria-current="page"] {
    color: var(--accent);
    font-weight: 600;
  }

  .site-search {
    position: relative;
    flex: 0 1 16rem;
    min-width: 9rem;
  }
  .site-search input {
    width: 100%;
    font: inherit;
    font-size: 0.9rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: transparent;
    color: inherit;
  }
  .site-search input:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
  }
  .search-results {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    right: 0;
    min-width: 16rem;
    max-height: 60vh;
    overflow-y: auto;
    margin: 0;
    padding: 0.25rem;
    list-style: none;
    background: Canvas;
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 6px 24px color-mix(in srgb, currentColor 15%, transparent);
    z-index: 40;
  }
  .search-results a {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
  }
  .search-results li.active a,
  .search-results a:hover {
    background: color-mix(in srgb, currentColor 8%, transparent);
  }
  .search-results .result-label {
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
  }
  .search-results .result-detail {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .page {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
  }
  .page.with-nav {
    grid-template-columns: 13rem minmax(0, 1fr);
  }

  .section-nav {
    position: sticky;
    top: calc(var(--header-h) + 1rem);
    align-self: start;
    font-size: 0.9rem;
    max-height: calc(100vh - var(--header-h) - 2rem);
    overflow-y: auto;
  }
  .section-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }
  .section-nav a {
    color: var(--muted);
    text-decoration: none;
  }
  .section-nav a:hover {
    color: var(--accent);
  }

  main {
    min-width: 0;
  }
  main h1 {
    margin-top: 0;
  }

  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--border);
    padding: 1rem 1.25rem 2rem;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .site-footer a {
    color: inherit;
  }

  /* One primary breakpoint: the section nav collapses into a top menu and
     code+visual pairs stack (handled in ApiEntry). */
  @media (max-width: 860px) {
    /* Keep the sticky header one row tall: drop the badge (still in the
       footer, so the pinned version stays on every page). */
    .header-badge {
      display: none;
    }
    .page.with-nav {
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
    }
    .section-nav {
      position: static;
      max-height: none;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.75rem;
    }
    .section-nav ul {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 1rem;
    }
  }
</style>
